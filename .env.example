# Nostr relays (comma-separated)
# Use /relay and /relay2 so frontend can access both local Docker relays through Vite proxy.
VITE_NOSTR_RELAYS=/relay,/relay2

# Local Docker relay target for the proxy (/relay -> this target)
VITE_LOCAL_RELAY_TARGET=ws://<relay_ip>:<relay_port_1>
# Second local Docker relay target for the proxy (/relay2 -> this target)
VITE_LOCAL_RELAY_TARGET_2=ws://<relay_ip>:<relay_port_2>

# HTTPS certificate files for local LAN access
VITE_SSL_CERT=./<your-cert-file>.pem
VITE_SSL_KEY=./<your-cert-key-file>.pem

# Dev mode (auto-login with dev key)
VITE_DEV_MODE=false

# Optional dev private key (never use production key)
# VITE_DEV_NSEC=nsec1...
